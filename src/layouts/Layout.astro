---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CompareBar from '../components/CompareBar.astro';
import { getAllLenses } from '../lib/lenses';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);

// Minimal id -> {brand, model} index so compare.js can render
// human-readable names in the floating comparison panel on any page —
// not just the home page, where the full card/table markup (and thus
// the lens names) already happens to be present in the DOM.
// Escaped defensively before embedding below: a literal closing script
// delimiter inside the JSON string would otherwise end the element
// early. No current lens name contains one, but it costs nothing.
const lensIndexJson = JSON.stringify(
  getAllLenses().map((lens) => ({ id: lens.id, brand: lens.brand, model: lens.model }))
).replace(/</g, '\\u003c');
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!--
      Anti-flash: the page is server-rendered in English, but i18n.js may
      immediately switch it to Chinese (saved preference or browser locale).
      Hide the page until that first pass completes so visitors never see
      an English → Chinese flicker. i18n.js marks `data-i18n-ready` on
      <html> as soon as it has applied the correct language. The timeout
      is a safety net in case JS fails to load.
    -->
    <style is:inline>
      html:not([data-i18n-ready]) body {
        visibility: hidden;
      }
    </style>
    <noscript>
      <style is:inline>
        body {
          visibility: visible !important;
        }
      </style>
    </noscript>
    <script is:inline>
      setTimeout(function revealFallback() {
        document.documentElement.setAttribute('data-i18n-ready', '');
      }, 1500);
    </script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content="index, follow" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
  </head>
  <body>
    <Header />
    <main class="container">
      <slot />
    </main>
    <Footer />
    <CompareBar />
    <script type="application/json" id="lens-index" is:inline set:html={lensIndexJson}></script>
    <script src="../scripts/i18n.js"></script>
    <script src="../scripts/compare.js"></script>
  </body>
</html>
