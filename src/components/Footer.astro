---
import { SITE_CONFIG } from '../lib/site';
import { t, localeHref, type Lang } from '../lib/i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="container">
    <p>
      <span>{t(lang, 'footer.copyright', { year })}</span> &middot;
      <span>{t(lang, 'footer.codeUnder')}</span>
      <a href={`${SITE_CONFIG.repoUrl}/blob/main/LICENSE`} target="_blank" rel="noopener noreferrer">{t(lang, 'footer.mit')}</a><span>{t(lang, 'footer.dataUnder')}</span>
      <a href={`${SITE_CONFIG.repoUrl}/blob/main/DATA_LICENSE.md`} target="_blank" rel="noopener noreferrer">{t(lang, 'footer.ccbysa')}</a> &middot;
      <a href={SITE_CONFIG.repoUrl} target="_blank" rel="noopener noreferrer">{t(lang, 'footer.contribute')}</a>
    </p>
    <p>
      <span>{t(lang, 'footer.disclaimer')}</span>
      <a href={localeHref(lang, 'about')}>{t(lang, 'footer.aboutLink')}</a>
      <span>{t(lang, 'footer.aboutLinkSuffix')}</span>
    </p>
  </div>
</footer>
