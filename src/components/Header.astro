---
import { SITE_CONFIG } from '../lib/site';
import { t, localeHref, localeAlternates, type Lang, type PagePath } from '../lib/i18n';

interface Props {
  lang: Lang;
  /** Current page, so the language switcher can point at the same page in
   *  another language rather than dumping the visitor on the home page. */
  path: PagePath;
}

const { lang, path } = Astro.props;

// One link per other language. With two locales this renders exactly one
// link (what used to be the toggle button); with three it renders two, with
// no change here. `data-set-locale` tells i18n.js to remember the choice —
// the link works without JS, it just won't be remembered for next time.
const otherLanguages = localeAlternates(path).filter((alt) => alt.lang !== lang);
---
<header class="site-header">
  <div class="container site-header__inner">
    <a class="site-header__brand" href={localeHref(lang)}>
      {/* Original geometric aperture/iris mark — hand-drawn, not a vendor
          logo or trademarked graphic (see the project's icon convention). */}
      <svg
        class="site-header__mark"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <circle cx="12" cy="12" r="9.25" />
        <path d="M12 7.4 L19.79 7.5 M15.98 9.7 L19.79 16.5 M15.98 14.3 L12 21 M12 16.6 L4.21 16.5 M8.02 14.3 L4.21 7.5 M8.02 9.7 L12 3" />
      </svg>
      <span class="site-header__brand-text">
        L-Mount Lens Guide
        <small>{t(lang, 'site.tagline')}</small>
      </span>
    </a>
    <nav class="site-header__nav">
      <a href={localeHref(lang)}>{t(lang, 'nav.lenses')}</a>
      <a href={localeHref(lang, 'about')}>{t(lang, 'nav.about')}</a>
      <a href={SITE_CONFIG.repoUrl} target="_blank" rel="noopener noreferrer">{t(lang, 'nav.github')}</a>
      <span class="lang-switch" role="group" aria-label={t(lang, 'lang.switchLabel')}>
        {otherLanguages.map((alt) => (
          <a
            class="btn"
            href={alt.href}
            hreflang={alt.htmlLang}
            lang={alt.htmlLang}
            data-set-locale={alt.lang}
          >{alt.label}</a>
        ))}
      </span>
    </nav>
  </div>
</header>
