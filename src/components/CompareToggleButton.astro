---
import type { Lens } from '../lib/types';

interface Props {
  lens: Lens;
  class?: string;
}

const { lens, class: className } = Astro.props;
---
<button
  type="button"
  class={`compare-toggle${className ? ` ${className}` : ''}`}
  data-compare-toggle
  data-lens-id={lens.id}
  aria-pressed="false"
  aria-label="Add to compare"
  title="Add to compare"
>
  <svg class="compare-toggle__icon" viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" focusable="false">
    <path d="M12 4v16M4 12h16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" />
  </svg>
</button>
