---
import type { Lens } from '../lib/types';
import {
  focalLengthLabel,
  apertureLabel,
  weightLabel,
  weightBucketId,
  lensSearchText,
} from '../lib/lenses';
import { t, brandName, localeHref, type Lang } from '../lib/i18n';
import CompareToggleButton from './CompareToggleButton.astro';

interface Props {
  lens: Lens;
  lang: Lang;
}

const { lens, lang } = Astro.props;
const brand = brandName(lang, lens.brand);
---
<div
  class="lens-card"
  data-lens-row
  data-brand={lens.brand}
  data-format={lens.format}
  data-focus-type={lens.focusType}
  data-lens-type={lens.lensType}
  data-alliance={String(lens.allianceMember)}
  data-weight-bucket={weightBucketId(lens.weightGram)}
  data-weight={lens.weightGram}
  data-focal-min={lens.focalLengthMin}
  data-focal-max={lens.focalLengthMax}
  data-max-aperture={lens.maxAperture}
  data-release-year={lens.releaseYear}
  data-search={lensSearchText(lens)}
>
  <a
    class="lens-card__link"
    href={localeHref(lang, `lenses/${lens.id}`)}
    aria-label={`${brand} ${lens.model}`}
  ></a>
  {/* The compare button is a flow sibling of the badges, not an overlay on top
      of them. As an absolutely-positioned overlay it was invisible to the badge
      row's layout, so badges simply ran underneath it — which only looked fine
      in Chinese by accident, because the Chinese badge text happens to be short
      enough. Keeping the two in one flex row means the badges can never claim
      the button's space, in any language. */}
  <div class="lens-card__top">
    <div class="lens-card__badges">
      <span class={`badge ${lens.allianceMember ? 'badge--alliance' : 'badge--third-party'}`}>
        {t(lang, lens.allianceMember ? 'card.allianceMember' : 'card.thirdParty')}
      </span>
      <span class="badge badge--outline">
        {t(lang, lens.format === 'Full Frame' ? 'filterBar.fullFrame' : 'filterBar.apsc')}
      </span>
      <span class="badge badge--outline">{lens.focusType}</span>
    </div>
    <CompareToggleButton lens={lens} lang={lang} class="lens-card__compare-toggle" />
  </div>
  <div class="lens-card__brand">{brand}</div>
  <div class="lens-card__model">{lens.model}</div>
  <dl class="lens-card__specs">
    <dt>{t(lang, 'card.focalLength')}</dt>
    <dd>{focalLengthLabel(lens)}</dd>
    <dt>{t(lang, 'card.maxAperture')}</dt>
    <dd>{apertureLabel(lens)}</dd>
    <dt>{t(lang, 'card.weight')}</dt>
    <dd>{weightLabel(lens)}</dd>
    <dt>{t(lang, 'card.released')}</dt>
    <dd>{lens.releaseYear}</dd>
  </dl>
</div>
