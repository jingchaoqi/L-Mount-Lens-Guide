---
import { getBrandsGrouped, getFocalRange, COMMON_FOCAL_LENGTHS } from '../lib/lenses';
import { t, brandName, type Lang } from '../lib/i18n';

interface Props {
  lang: Lang;
  /** Total lens count, for the initial "Showing N of N" line — rendered
   *  server-side so it is correct in this page's language before filter.js
   *  ever runs. */
  total: number;
}

const { lang, total } = Astro.props;

const { alliance: allianceBrands, thirdParty: thirdPartyBrands } = getBrandsGrouped();
const focalRange = getFocalRange();

// The slider itself runs on a log scale (raw 0-1000) rather than linear mm,
// since focal lengths cluster heavily at the wide-angle end (14-50mm) — a
// linear scale would give the whole 14-100mm range only ~15% of the track.
// Tick positions are computed with the same formula client-side (filter.js).
const focalLogMin = Math.log(focalRange.min);
const focalLogMax = Math.log(focalRange.max);
function focalToPercent(mm: number): number {
  return ((Math.log(mm) - focalLogMin) / (focalLogMax - focalLogMin)) * 100;
}
const focalTicks = COMMON_FOCAL_LENGTHS.filter((v) => v >= focalRange.min && v <= focalRange.max);
---
<div class="filter-bar" id="filter-bar">
  <input
    type="search"
    id="search-input"
    class="filter-bar__search"
    placeholder={t(lang, 'filterBar.searchPlaceholder')}
    aria-label={t(lang, 'filterBar.searchAriaLabel')}
  />

  <div class="filter-bar__grid">
    <div class="filter-group">
      <label for="filter-brand">{t(lang, 'filterBar.brand')}</label>
      <select id="filter-brand" data-filter="brand">
        <option value="all">{t(lang, 'filterBar.allBrands')}</option>
        <optgroup label={t(lang, 'filterBar.allianceBrandsGroup')}>
          {allianceBrands.map((brand) => <option value={brand}>{brandName(lang, brand)}</option>)}
        </optgroup>
        <optgroup label={t(lang, 'filterBar.thirdPartyBrandsGroup')}>
          {thirdPartyBrands.map((brand) => <option value={brand}>{brandName(lang, brand)}</option>)}
        </optgroup>
      </select>
    </div>

    <div class="filter-group">
      <label for="filter-format">{t(lang, 'filterBar.format')}</label>
      <select id="filter-format" data-filter="format">
        <option value="all">{t(lang, 'filterBar.allFormats')}</option>
        <option value="Full Frame">{t(lang, 'filterBar.fullFrame')}</option>
        <option value="APS-C">{t(lang, 'filterBar.apsc')}</option>
      </select>
    </div>

    <div class="filter-group">
      <label for="filter-focus">{t(lang, 'filterBar.focus')}</label>
      <select id="filter-focus" data-filter="focusType">
        <option value="all">{t(lang, 'filterBar.allFocus')}</option>
        <option value="AF">{t(lang, 'filterBar.af')}</option>
        <option value="MF">{t(lang, 'filterBar.mf')}</option>
      </select>
    </div>

    <div class="filter-group">
      <label for="filter-lenstype">{t(lang, 'filterBar.lensType')}</label>
      <select id="filter-lenstype" data-filter="lensType">
        <option value="all">{t(lang, 'filterBar.allLensTypes')}</option>
        <option value="Prime">{t(lang, 'filterBar.prime')}</option>
        <option value="Zoom">{t(lang, 'filterBar.zoom')}</option>
      </select>
    </div>

    <div class="filter-group">
      <label for="filter-alliance">{t(lang, 'filterBar.alliance')}</label>
      <select id="filter-alliance" data-filter="alliance">
        <option value="all">{t(lang, 'filterBar.allLenses')}</option>
        <option value="true">{t(lang, 'filterBar.allianceMember')}</option>
        <option value="false">{t(lang, 'filterBar.thirdParty')}</option>
      </select>
    </div>

    <div class="filter-group filter-group--wide">
      <label id="focal-range-label">{t(lang, 'filterBar.focalLength')}</label>
      <div
        class="range-slider"
        id="focal-range"
        role="group"
        aria-labelledby="focal-range-label"
        data-focal-min={focalRange.min}
        data-focal-max={focalRange.max}
      >
        <div class="range-slider__track">
          <div class="range-slider__fill" id="focal-range-fill"></div>
        </div>
        <input
          type="range"
          id="focal-range-min-input"
          min="0"
          max="1000"
          value="0"
          step="1"
          aria-label={t(lang, 'filterBar.focalMinLabel')}
        />
        <input
          type="range"
          id="focal-range-max-input"
          min="0"
          max="1000"
          value="1000"
          step="1"
          aria-label={t(lang, 'filterBar.focalMaxLabel')}
        />
      </div>
      <div class="range-slider__ticks" id="focal-range-ticks">
        {focalTicks.map((v) => (
          <button
            type="button"
            class="range-slider__tick"
            data-focal-value={v}
            style={`left:calc((100% - 16px) * ${focalToPercent(v)} / 100 + 8px)`}
            aria-label={`${v}mm`}
          >
            <span class="range-slider__tick-mark" aria-hidden="true"></span>
            <span class="range-slider__tick-label">{v}</span>
          </button>
        ))}
      </div>
      <div class="range-slider__value" id="focal-range-value">{focalRange.min}mm – {focalRange.max}mm</div>
      <p class="filter-hint">{t(lang, 'filterBar.focalRangeHint')}</p>
    </div>

  </div>

  <div class="filter-bar__footer">
    <span class="filter-count" id="filter-count" aria-live="polite">
      {t(lang, 'filterBar.showingCount', { count: total, total })}
    </span>
    <div style="display:flex; gap:0.75rem; align-items:center; flex-wrap:wrap;">
      <div class="sort-bar">
        <label for="sort-select">{t(lang, 'filterBar.sortBy')}</label>
        <select id="sort-select">
          <option value="focal-asc">{t(lang, 'filterBar.sort.focalAsc')}</option>
          <option value="focal-desc">{t(lang, 'filterBar.sort.focalDesc')}</option>
          <option value="aperture-asc">{t(lang, 'filterBar.sort.apertureAsc')}</option>
          <option value="weight-asc">{t(lang, 'filterBar.sort.weightAsc')}</option>
          <option value="weight-desc">{t(lang, 'filterBar.sort.weightDesc')}</option>
          <option value="year-desc">{t(lang, 'filterBar.sort.yearDesc')}</option>
          <option value="year-asc">{t(lang, 'filterBar.sort.yearAsc')}</option>
        </select>
      </div>
      <div class="view-toggle" id="view-toggle">
        <button type="button" class="btn is-active" data-view="cards">{t(lang, 'filterBar.cards')}</button>
        <button type="button" class="btn" data-view="table">{t(lang, 'filterBar.table')}</button>
      </div>
      <button type="button" class="btn" id="clear-filters">{t(lang, 'filterBar.clear')}</button>
    </div>
  </div>
</div>
