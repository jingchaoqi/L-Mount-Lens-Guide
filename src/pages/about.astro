---
import Layout from '../layouts/Layout.astro';
import { SITE_CONFIG } from '../lib/site';

const title = 'About & Disclaimer — L-Mount Lens Guide';
const description = 'L-Mount Lens Guide is an unofficial, community-maintained project. '
  + 'It is not affiliated with, sponsored by, or endorsed by Leica Camera AG, the L-Mount Alliance, '
  + 'Panasonic, Sigma, or any other manufacturer.';
---
<Layout title={title} description={description}>
  <div class="prose">
    <h1 data-i18n="about.title">About &amp; Disclaimer</h1>

    <p data-i18n="about.intro" data-i18n-html>
      <strong>L-Mount Lens Guide</strong> is an unofficial, community-maintained directory of
      lenses for the L-Mount lens mount system. It is a volunteer open-source project, built and
      maintained by photography enthusiasts, not by any camera or lens manufacturer.
    </p>

    <h2 data-i18n="about.h.noAffiliation">No affiliation, sponsorship, or endorsement</h2>
    <p data-i18n="about.noAffiliation1" data-i18n-html>
      This project is <strong>not affiliated with, sponsored by, or endorsed by</strong> Leica Camera AG,
      the L-Mount Alliance, Panasonic, Sigma, or any other brand mentioned on this site. Product names,
      brand names, and specifications referenced here belong to their respective owners and are used
      solely for identification and informational purposes (nominative fair use).
    </p>
    <p data-i18n="about.noAffiliation2" data-i18n-html>
      <strong>"L-Mount" and "L-Mount Alliance" are trademarks of Leica Camera AG.</strong> Their use on
      this site refers only to the lens mount standard and its ecosystem, and does not imply any
      business relationship with Leica Camera AG.
    </p>
    <p data-i18n="about.noAffiliation3">
      This site does not use official manufacturer logos, the Leica red dot, or any other
      manufacturer trademark graphics. Brand names are shown as plain text only.
    </p>

    <h2 data-i18n="about.h.allianceMeaning">What "L-Mount Alliance member" means on this site</h2>
    <p data-i18n="about.allianceMeaning1" data-i18n-html>
      Each lens entry is tagged as either an <strong>L-Mount Alliance member</strong> product or a
      <strong>third-party (non-Alliance)</strong> product:
    </p>
    <ul>
      <li data-i18n="about.allianceMeaning.member" data-i18n-html>
        <strong>L-Mount Alliance member</strong> — the brand is a publicly listed member of the
        <a href="https://l-mount.com/" target="_blank" rel="noopener noreferrer">L-Mount Alliance</a>
        (as of 2026: Leica, Panasonic, Sigma, Ernst Leitz Wetzlar, DJI, Astrodesign, Samyang, Blackmagic
        Design, Sirui, Viltrox, and Freefly). This reflects the brand's membership status, not a
        per-lens certification.
      </li>
      <li data-i18n="about.allianceMeaning.thirdParty" data-i18n-html>
        <strong>Third-party (non-Alliance)</strong> — the manufacturer is not an L-Mount Alliance
        member. Listing a lens here only means the manufacturer sells, or has announced, an L-Mount
        version of that lens. It is <strong>not</strong> a claim of official compatibility testing,
        certification, or endorsement by the L-Mount Alliance or any Alliance member. Third-party
        lenses may have compatibility limitations (autofocus behavior, firmware support, stabilization
        coordination, etc.) that differ from Alliance-member lenses — always check current compatibility
        notes from the lens manufacturer before purchasing.
      </li>
    </ul>

    <h2 data-i18n="about.h.dataAccuracy">Data accuracy</h2>
    <p>
      <span data-i18n="about.dataAccuracy1">
        Lens specifications are compiled from publicly available manufacturer sources and community
        references. They may contain errors, omissions, or become outdated as products are updated or
        discontinued. Every lens entry lists its source links — always verify specifications against the
        manufacturer's current published data before making a purchasing decision. If you spot an error,
        please open an issue or pull request.
      </span>
      (<a href={SITE_CONFIG.repoUrl} data-i18n="about.repoLink">the project repository</a>)
    </p>

    {/* Temporarily hidden per request — re-enable by uncommenting.
    <h2 data-i18n="about.h.commercialLinks">Commercial links</h2>
    <p data-i18n="about.commercialLinks1" data-i18n-html>
      This site currently contains only plain, non-monetized "search this retailer" links — no
      affiliate program is active today. The data model reserves fields (<code>affiliateUrls</code>,
      <code>retailerSearchUrls[].sponsored</code>) for future monetized links. If and when any sponsored
      or affiliate link is added, it will be clearly and visibly labeled "sponsored" or "affiliate" in
      the UI, and outbound links will use <code>rel="sponsored nofollow"</code> as appropriate.
    </p>
    */}

    <h2 data-i18n="about.h.license">License</h2>
    <p data-i18n="about.license1" data-i18n-html>
      Site source code is available under the MIT License. Lens specification data is available under
      the Creative Commons Attribution-ShareAlike 4.0 (CC BY-SA 4.0) license. See
      <code>LICENSE</code> and <code>DATA_LICENSE.md</code> in the project repository for details.
    </p>

    <h2 data-i18n="about.h.contact">Contact / contribute</h2>
    <p>
      <span data-i18n="about.contact1" data-i18n-html>
        This is an open-source project — contributions, corrections, and new lens submissions are
        welcome via GitHub. See <code>CONTRIBUTING.md</code> for how to submit a new lens entry.
      </span>
      {' '}<a href={SITE_CONFIG.repoUrl} data-i18n="about.repoLink2">GitHub</a>
    </p>
  </div>
</Layout>
