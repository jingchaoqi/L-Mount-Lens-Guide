---
import Layout from '../../layouts/Layout.astro';
import FilterBar from '../../components/FilterBar.astro';
import LensCard from '../../components/LensCard.astro';
import LensTable from '../../components/LensTable.astro';
import { getAllLenses } from '../../lib/lenses';
import { t, localeStaticPaths, langFromParam } from '../../lib/i18n';

// One statically-rendered page per locale: '/' for the default locale,
// '/<code>/' for every other one. Adding a language to locales.js adds its
// pages here automatically.
export function getStaticPaths() {
  return localeStaticPaths();
}

const lang = langFromParam(Astro.params.locale);
const lenses = getAllLenses();

// Hero stat chips — derived from the data, never hard-coded.
const brandCount = new Set(lenses.map((l) => l.brand)).size;
const allianceBrandCount = new Set(
  lenses.filter((l) => l.allianceMember).map((l) => l.brand)
).size;
---
<Layout
  lang={lang}
  path=""
  title={t(lang, 'seo.homeTitle')}
  description={t(lang, 'seo.homeDescription', { count: lenses.length })}
>
  <section class="hero">
    <div class="hero__main">
      <h1 class="hero__title">{t(lang, 'home.title')}</h1>
      <p class="hero__intro">{t(lang, 'home.intro')}</p>
    </div>
    <div class="hero__stats">
      <div class="hero__stat">
        <span class="hero__stat-num">{lenses.length}</span>
        <span class="hero__stat-label">{t(lang, 'home.statLenses')}</span>
      </div>
      <div class="hero__stat">
        <span class="hero__stat-num">{brandCount}</span>
        <span class="hero__stat-label">{t(lang, 'home.statBrands')}</span>
      </div>
      <div class="hero__stat">
        <span class="hero__stat-num">{allianceBrandCount}</span>
        <span class="hero__stat-label">{t(lang, 'home.statAlliance')}</span>
      </div>
    </div>
  </section>

  <FilterBar lang={lang} total={lenses.length} />

  <div id="view-container" class="view-cards">
    <div class="lens-grid" id="lens-grid">
      {lenses.map((lens) => <LensCard lens={lens} lang={lang} />)}
    </div>
    <LensTable lenses={lenses} lang={lang} />
  </div>

  <p class="no-results" id="no-results" hidden>{t(lang, 'filterBar.noResults')}</p>

  <script src="../../scripts/filter.js"></script>
</Layout>
