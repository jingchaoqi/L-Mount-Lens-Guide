---
import Layout from '../layouts/Layout.astro';
import CompareToggleButton from '../components/CompareToggleButton.astro';
import { getAllLenses, focalLengthLabel, apertureLabel, weightLabel } from '../lib/lenses';

const lenses = getAllLenses();
const base = import.meta.env.BASE_URL;
const title = 'Lens Comparison — L-Mount Lens Guide';
const description = 'Compare specifications of selected L-Mount lenses side by side.';
---
<Layout title={title} description={description}>
  <a class="back-link" href={base} data-i18n="detail.back">&larr; Back to lens list</a>

  <h1 data-i18n="compare.title">Lens Comparison</h1>
  <p style="color:var(--color-text-muted); max-width:70ch;" data-i18n="compare.intro">
    Compare the specifications of your selected lenses side by side.
  </p>

  <div class="compare-wrap" id="compare-wrap">
    <div class="compare-grid" id="compare-grid" hidden>
      <div class="compare-labels">
        <div class="compare-row compare-row--header"></div>
        <div class="compare-row" data-i18n="spec.allianceMember">L-Mount Alliance member</div>
        <div class="compare-row" data-i18n="spec.format">Format</div>
        <div class="compare-row" data-i18n="spec.lensType">Lens type</div>
        <div class="compare-row" data-i18n="spec.focusType">Focus type</div>
        <div class="compare-row" data-i18n="spec.focalLength">Focal length</div>
        <div class="compare-row" data-i18n="spec.maxAperture">Maximum aperture</div>
        <div class="compare-row" data-i18n="spec.minAperture">Minimum aperture</div>
        <div class="compare-row" data-i18n="spec.weight">Weight</div>
        <div class="compare-row" data-i18n="spec.filterThread">Filter thread</div>
        <div class="compare-row" data-i18n="spec.minFocusDistance">Minimum focus distance</div>
        <div class="compare-row" data-i18n="spec.maxMagnification">Maximum magnification</div>
        <div class="compare-row" data-i18n="spec.stabilization">Optical stabilization</div>
        <div class="compare-row" data-i18n="spec.weatherSealed">Weather sealed</div>
        <div class="compare-row" data-i18n="spec.releaseYear">Release year</div>
      </div>

      {lenses.map((lens) => {
        const brandKey = `brand.${lens.brand}`;
        const formatKey = lens.format === 'Full Frame' ? 'filterBar.fullFrame' : 'filterBar.apsc';
        const lensTypeKey = lens.lensType === 'Prime' ? 'filterBar.prime' : 'filterBar.zoom';
        const focusKey = lens.focusType === 'AF' ? 'detail.af' : 'detail.mf';
        return (
          <div class="compare-column" data-lens-id={lens.id} hidden>
            <div class="compare-row compare-row--header">
              <a href={`${base}lenses/${lens.id}`} title={`${lens.brand} ${lens.model}`}>
                <span data-i18n={brandKey}>{lens.brand}</span> {lens.model}
              </a>
              <CompareToggleButton lens={lens} class="compare-remove" />
            </div>
            <div class="compare-row" data-i18n={lens.allianceMember ? 'spec.yes' : 'spec.noThirdParty'}>
              {lens.allianceMember ? 'Yes' : 'No (third-party)'}
            </div>
            <div class="compare-row" data-i18n={formatKey}>{lens.format}</div>
            <div class="compare-row" data-i18n={lensTypeKey}>{lens.lensType}</div>
            <div class="compare-row" data-i18n={focusKey}>
              {lens.focusType === 'AF' ? 'Autofocus' : 'Manual focus'}
            </div>
            <div class="compare-row">{focalLengthLabel(lens)}</div>
            <div class="compare-row">{apertureLabel(lens)}</div>
            <div class="compare-row">f/{lens.minAperture}</div>
            <div class="compare-row">{weightLabel(lens)}</div>
            <div class="compare-row" data-i18n={lens.filterThreadMm ? undefined : 'spec.filterThreadNone'}>
              {lens.filterThreadMm ? `${lens.filterThreadMm}mm` : 'None / not applicable'}
            </div>
            <div class="compare-row">{lens.minFocusDistanceM}m</div>
            <div class="compare-row">{lens.maxMagnification}x</div>
            <div class="compare-row" data-i18n={lens.stabilization ? 'spec.yes' : 'spec.no'}>
              {lens.stabilization ? 'Yes' : 'No'}
            </div>
            <div
              class="compare-row"
              data-i18n={lens.weatherSealed === null ? 'spec.notSpecified' : (lens.weatherSealed ? 'spec.yes' : 'spec.no')}
            >
              {lens.weatherSealed === null ? 'Not specified' : (lens.weatherSealed ? 'Yes' : 'No')}
            </div>
            <div class="compare-row">{lens.releaseYear}</div>
          </div>
        );
      })}
    </div>

    <p class="compare-empty" id="compare-empty">
      <span data-i18n="compare.empty">No lenses selected for comparison.</span><br />
      <a class="btn" href={base} data-i18n="compare.emptyAction">Back to lens list</a>
    </p>
  </div>

  <a class="back-link" href={base} data-i18n="detail.back">&larr; Back to lens list</a>
</Layout>
