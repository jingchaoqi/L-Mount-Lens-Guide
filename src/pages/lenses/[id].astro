---
import Layout from '../../layouts/Layout.astro';
import {
  getAllLenses,
  getLensById,
  focalLengthLabel,
  apertureLabel,
  weightLabel,
  lensSeo,
} from '../../lib/lenses';

export function getStaticPaths() {
  return getAllLenses().map((lens) => ({
    params: { id: lens.id },
  }));
}

const { id } = Astro.params;
const lens = getLensById(id as string);

if (!lens) {
  throw new Error(`Lens not found: ${id}`);
}

const { title, description } = lensSeo(lens);
const base = import.meta.env.BASE_URL;

const brandKey = `brand.${lens.brand}`;
const formatKey = lens.format === 'Full Frame' ? 'filterBar.fullFrame' : 'filterBar.apsc';
const lensTypeKey = lens.lensType === 'Prime' ? 'filterBar.prime' : 'filterBar.zoom';
---
<Layout title={title} description={description}>
  <a class="back-link" href={base} data-i18n="detail.back">&larr; Back to lens list</a>

  <div class="detail-header">
    <div class="detail-header__brand" data-i18n={brandKey}>{lens.brand}</div>
    <h1 class="detail-header__model">{lens.model}</h1>
    <div class="lens-card__badges">
      <span
        class={`badge ${lens.allianceMember ? 'badge--alliance' : 'badge--third-party'}`}
        data-i18n={lens.allianceMember ? 'detail.allianceMember' : 'detail.thirdParty'}
      >
        {lens.allianceMember ? 'L-Mount Alliance member' : 'Third-party (non-Alliance)'}
      </span>
      <span class="badge badge--outline" data-i18n={formatKey}>{lens.format}</span>
      <span class="badge badge--outline" data-i18n={lensTypeKey}>{lens.lensType}</span>
      <span class="badge badge--outline" data-i18n={lens.focusType === 'AF' ? 'detail.af' : 'detail.mf'}>
        {lens.focusType === 'AF' ? 'Autofocus' : 'Manual focus'}
      </span>
      {lens.category.map((cat) => <span class="badge badge--outline" data-i18n={`category.${cat}`}>{cat}</span>)}
    </div>
  </div>

  {!lens.allianceMember && (
    <div class="disclaimer-banner">
      <strong data-i18n="detail.notAlliance">Not an L-Mount Alliance product.</strong>{' '}
      <span data-i18n={brandKey}>{lens.brand}</span>{' '}
      <span data-i18n="detail.notAllianceBody">
        is not a listed member of the L-Mount Alliance. This entry means the manufacturer offers
        (or claims) an L-Mount version of this lens — it does not imply official certification, testing, or
        endorsement by the L-Mount Alliance, Leica Camera AG, Panasonic, or Sigma. See the About & Disclaimer page.
      </span>
    </div>
  )}

  <div class="link-row">
    <a class="btn btn--primary" href={lens.officialUrl} target="_blank" rel="noopener noreferrer" data-i18n="detail.officialPage">Official page</a>
    {lens.affiliateUrls.map((r) => (
      <a class="btn" href={r.url} target="_blank" rel="noopener noreferrer nofollow sponsored">
        {r.label} {r.sponsored ? <span data-i18n="detail.sponsored">(sponsored)</span> : null}
      </a>
    ))}
  </div>

  <h2 class="section-title" data-i18n="detail.specifications">Specifications</h2>
  <table class="spec-table">
    <tbody>
      <tr><th data-i18n="spec.mount">Mount</th><td>{lens.mount}</td></tr>
      <tr><th data-i18n="spec.format">Format</th><td data-i18n={formatKey}>{lens.format}</td></tr>
      <tr><th data-i18n="spec.lensType">Lens type</th><td data-i18n={lensTypeKey}>{lens.lensType}</td></tr>
      <tr><th data-i18n="spec.focusType">Focus type</th><td data-i18n={lens.focusType === 'AF' ? 'detail.af' : 'detail.mf'}>{lens.focusType === 'AF' ? 'Autofocus' : 'Manual focus'}</td></tr>
      <tr><th data-i18n="spec.focalLength">Focal length</th><td>{focalLengthLabel(lens)}</td></tr>
      <tr><th data-i18n="spec.maxAperture">Maximum aperture</th><td>{apertureLabel(lens)}</td></tr>
      <tr><th data-i18n="spec.minAperture">Minimum aperture</th><td>f/{lens.minAperture}</td></tr>
      <tr><th data-i18n="spec.weight">Weight</th><td>{weightLabel(lens)} ({lens.weightGram}g)</td></tr>
      <tr><th data-i18n="spec.filterThread">Filter thread</th><td data-i18n={lens.filterThreadMm ? undefined : 'spec.filterThreadNone'}>{lens.filterThreadMm ? `${lens.filterThreadMm}mm` : 'None / not applicable'}</td></tr>
      <tr><th data-i18n="spec.minFocusDistance">Minimum focus distance</th><td>{lens.minFocusDistanceM}m</td></tr>
      <tr><th data-i18n="spec.maxMagnification">Maximum magnification</th><td>{lens.maxMagnification}x</td></tr>
      <tr><th data-i18n="spec.stabilization">Optical stabilization</th><td data-i18n={lens.stabilization ? 'spec.yes' : 'spec.no'}>{lens.stabilization ? 'Yes' : 'No'}</td></tr>
      <tr><th data-i18n="spec.weatherSealed">Weather sealed</th><td data-i18n={lens.weatherSealed === null ? 'spec.notSpecified' : (lens.weatherSealed ? 'spec.yes' : 'spec.no')}>{lens.weatherSealed === null ? 'Not specified' : (lens.weatherSealed ? 'Yes' : 'No')}</td></tr>
      <tr><th data-i18n="spec.releaseYear">Release year</th><td>{lens.releaseYear}</td></tr>
      <tr><th data-i18n="spec.allianceMember">L-Mount Alliance member</th><td data-i18n={lens.allianceMember ? 'spec.yes' : 'spec.noThirdParty'}>{lens.allianceMember ? 'Yes' : 'No (third-party)'}</td></tr>
    </tbody>
  </table>

  {lens.notes && (
    <>
      <h2 class="section-title" data-i18n="detail.notes">Notes</h2>
      {lens.notesZh ? (
        <>
          <p data-lang-content="en">{lens.notes}</p>
          <p data-lang-content="zh">{lens.notesZh}</p>
        </>
      ) : (
        <p>{lens.notes}</p>
      )}
    </>
  )}

  <h2 class="section-title" data-i18n="detail.dataSources">Data sources</h2>
  <ul>
    {lens.sourceUrls.map((url) => (
      <li><a href={url} target="_blank" rel="noopener noreferrer">{url}</a></li>
    ))}
  </ul>
  <p style="color:var(--color-text-muted); font-size:0.85rem;" data-i18n="detail.sourcesFooter">
    Specifications are compiled from the sources above and may contain errors or become outdated.
    Always confirm critical specs with the manufacturer before purchase.
    See About &amp; Disclaimer.
  </p>

  <a class="back-link" href={base} data-i18n="detail.back">&larr; Back to lens list</a>
</Layout>
